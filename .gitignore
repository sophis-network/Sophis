# Compilação e Binários
/target
**/*.rs.bk
*.pdb

# Logs e Dados locais de teste
*.log
/data
/db
.sophisd/

# Configurações de IDE
.vscode/
.idea/
*.swp

# Arquivos de ambiente e chaves (CRÍTICO)
.env
.env.*
*.pem
/keys
mnemonic.txt
founder-mining.key
relayer.key
*.relayer.key
*_wallet.json
*.keystore

# Generated by Cargo
# will have compiled files and executables
debug/

# risc0 guest crates are separate workspaces — Cargo.lock is build-only artifact
rollup/host/guest/Cargo.lock

# wasm-pack output
wasm/release/

# Python (devnet scripts, build helpers)
__pycache__/
*.pyc
*.pyo

# Coverage
*.profraw
lcov.info
/coverage/

# Merge / rebase artifacts
*.orig
*.rej

# Node (caso ferramentas JS apareçam)
node_modules/

# OS / IDE clutter
.DS_Store
Thumbs.db
desktop.ini

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/